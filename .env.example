# Application
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional dev-only onboarding preview (unauthenticated onboarding for local testing)
# Never enable this in production.
# NEXT_PUBLIC_DEV_ONBOARDING_PREVIEW=true

# ============================================================================
# Runtime Mode: Choose "clerk"+"convex" OR "supabase"+"supabase" (default)
# ============================================================================
NEXT_PUBLIC_AUTH_PROVIDER=clerk
NEXT_PUBLIC_DATA_PROVIDER=convex

# ============================================================================
# Clerk (required when AUTH_PROVIDER=clerk)
# ============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret
CLERK_JWT_ISSUER_DOMAIN=https://your-instance.clerk.accounts.dev

# ============================================================================
# Convex (required when DATA_PROVIDER=convex)
# ============================================================================
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_DEPLOYMENT=dev:your-deployment-name
CONVEX_SEED_IMPORT_SECRET=replace-with-a-long-random-secret

# ============================================================================
# Supabase (required when DATA_PROVIDER=supabase; optional in convex mode)
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-SUPABASE-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ============================================================================
# Stripe (always required)
# ============================================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_key

# Stripe Price IDs (get from Stripe Dashboard)
# Monthly prices
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxx
# Annual prices (40% discount)
STRIPE_PRO_ANNUAL_PRICE_ID=price_xxx
# Featured Location Add-on (per-location pricing)
STRIPE_FEATURED_MONTHLY_PRICE_ID=price_xxx
STRIPE_FEATURED_ANNUAL_PRICE_ID=price_xxx

# Add-on Pack Prices
STRIPE_ADDON_EXTRA_USERS_PRICE_ID=price_xxx
STRIPE_ADDON_LOCATION_PACK_PRICE_ID=price_xxx
STRIPE_ADDON_JOB_PACK_PRICE_ID=price_xxx
STRIPE_ADDON_STORAGE_PACK_PRICE_ID=price_xxx
STRIPE_ADDON_HOMEPAGE_PLACEMENT_PRICE_ID=price_xxx

# ============================================================================
# External Services (always required)
# ============================================================================

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Resend Email (optional - emails logged if not set)
RESEND_API_KEY=re_your_resend_api_key

# Email sending uses goodaba.com as the unified sending domain:
# - "Find ABA Therapy <noreply@goodaba.com>"
# - "GoodABA Jobs <noreply@goodaba.com>"
# - "GoodABA <noreply@goodaba.com>"
# EMAIL_FROM=noreply@goodaba.com

# Optional: Per-brand email overrides
# EMAIL_FROM_THERAPY=noreply@goodaba.com
# EMAIL_FROM_JOBS=noreply@goodaba.com
# EMAIL_FROM_PARENT=noreply@goodaba.com
# EMAIL_FROM_GOODABA=noreply@goodaba.com

# Cron Jobs
CRON_SECRET=your_cron_secret_here
